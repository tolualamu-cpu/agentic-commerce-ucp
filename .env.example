# ─── Required ───────────────────────────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...


# ─── Optional ───────────────────────────────────────────────────────────────

# Your name (shown in the welcome panel)
USER_NAME=Friend

# Stripe (test mode). If unset, an offline tokeniser is used — works
# end-to-end without a real Stripe account but no real Stripe IDs.
# Get a test key from https://dashboard.stripe.com/test/apikeys
STRIPE_TEST_KEY=sk_test_...

# Shopify sandbox store. If unset, defaults to a built-in stub merchant
# at "demo-shop.myshopify.com" — works fully offline.
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_SHOP_DOMAIN=demo-shop.myshopify.com

# RFC 9421 signing key. If unset, a fresh Ed25519 keypair is generated
# every run. For deterministic merchant verification across runs, persist:
#   python3 -c "from ucp.signing import generate_keypair; \
#               priv, _, _ = generate_keypair('agent'); print(priv)"
AGENT_PRIVATE_KEY_PEM=
AGENT_KEY_ID=agent-key-1

# AP2 mandate HMAC key. If unset, regenerated every run (so mandates from
# a previous session won't verify). For persistence:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
AP2_SIGNING_KEY=


# ─── Storage ────────────────────────────────────────────────────────────────

# TinyDB JSON file. Holds mandates, orders, spend records, audit log.
# Keep this OUTSIDE the project tree. `uvicorn --reload` watches the working
# directory, so an in-tree DB makes every per-session file + write trigger a
# server restart that drops the SSE/gate-WS connection — the page "flickers"
# and chat/purchase die mid-flight. ${HOME}/.carto stays off the watcher.
DB_PATH=${HOME}/.carto/agentic_commerce.json


# ─── Models (rarely changed) ────────────────────────────────────────────────

ORCHESTRATOR_MODEL=claude-sonnet-4-6
SUBAGENT_MODEL=claude-haiku-4-5
